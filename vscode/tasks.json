{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-g",
                "-std=c++17", 
                
                "-ffunction-sections",
                "-fdata-sections",

                "-I", "C:/OGL/include",
                "-L", "C:/OGL/lib", 
                
                "${file}",
                "C:/OGL/hsource/*.cpp",
                "C:/OGL/src/glad.c",
                
                "-lglfw3dll", 

                "-Wl,--gc-sections",
                
                "-o",
                "C:/OGL/exec/a.exe"
            ],
            "options": {
                "cwd": "C:/OGL"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "compiler: C:/msys64/ucrt64/bin/g++.exe"
        }
    ]
}